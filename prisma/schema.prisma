generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Article {
  id           String   @id @default(uuid())
  type         String   @default("article")
  title        String
  authors      String?
  year         Int?
  journal      String?
  bookTitle    String?
  publisher    String?
  edition      String?
  pages        String?
  url          String?
  doi          String?
  abstract     String?
  tags         String?
  status       String   @default("want_to_read")
  addedAt      DateTime @default(now())
  finishedAt   DateTime?
  geminiReview String?
}
